rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verifiedEmail() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function isMember(orgId) {
      return signedIn() && exists(/databases/$(database)/documents/memberships/$(orgId + "_" + request.auth.uid));
    }

    function membership(orgId) {
      return get(/databases/$(database)/documents/memberships/$(orgId + "_" + request.auth.uid)).data;
    }

    function canManage(orgId) {
      return isMember(orgId) && (
        membership(orgId).permission_level in ["admin", "committee"] ||
        membership(orgId).role in ["president", "secretary", "treasurer", "committee"]
      );
    }

    function isAdmin(orgId) {
      return isMember(orgId) && (
        membership(orgId).permission_level == "admin" ||
        membership(orgId).role in ["president", "secretary", "treasurer"]
      );
    }

    function meetingOrgId(meetingId) {
      return get(/databases/$(database)/documents/meetings/$(meetingId)).data.organization_id;
    }

    function canReadMeetingChild(meetingId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)) && isMember(meetingOrgId(meetingId));
    }

    function canWriteMeetingChild(meetingId) {
      return exists(/databases/$(database)/documents/meetings/$(meetingId)) && canManage(meetingOrgId(meetingId));
    }

    function immutableOrg() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["organization_id"]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isMember(orgId);
      allow create: if verifiedEmail() && request.resource.data.created_by == request.auth.uid;
      allow update: if isAdmin(orgId);
      allow delete: if isAdmin(orgId);
    }

    match /memberships/{membershipId} {
      allow read: if signedIn() && (
        resource.data.user_id == request.auth.uid ||
        isMember(resource.data.organization_id)
      );
      allow create, update, delete: if false;
    }

    match /organization_roles/{roleId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if isAdmin(request.resource.data.organization_id);
      allow update, delete: if isAdmin(resource.data.organization_id);
    }

    match /teams/{teamId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id) &&
        request.resource.data.lead_user_id == request.auth.uid;
      allow update: if isAdmin(resource.data.organization_id) ||
        (canManage(resource.data.organization_id) && resource.data.lead_user_id == request.auth.uid && immutableOrg());
      allow delete: if isAdmin(resource.data.organization_id) ||
        (canManage(resource.data.organization_id) && resource.data.lead_user_id == request.auth.uid);
    }

    match /tasks/{taskId} {
      allow read: if isMember(resource.data.organization_id) &&
        (resource.data.visibility != "private" || resource.data.created_by == request.auth.uid);
      allow create: if (
        canManage(request.resource.data.organization_id) ||
        (
          isMember(request.resource.data.organization_id) &&
          request.resource.data.visibility == "private" &&
          request.resource.data.created_by == request.auth.uid &&
          request.resource.data.assigned_to == request.auth.uid
        )
      );
      allow update: if immutableOrg() && (
        canManage(resource.data.organization_id) ||
        (
          isMember(resource.data.organization_id) &&
          resource.data.assigned_to == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        ) ||
        (
          isMember(resource.data.organization_id) &&
          resource.data.visibility == "private" &&
          resource.data.created_by == request.auth.uid
        )
      );
      allow delete: if canManage(resource.data.organization_id) ||
        (isMember(resource.data.organization_id) && resource.data.visibility == "private" && resource.data.created_by == request.auth.uid);
    }

    match /meetings/{meetingId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id);
      allow update: if canManage(resource.data.organization_id) && immutableOrg();
      allow delete: if canManage(resource.data.organization_id);
    }

    match /meeting_notes/{noteId} {
      allow read: if canReadMeetingChild(resource.data.meeting_id);
      allow create: if canWriteMeetingChild(request.resource.data.meeting_id) &&
        request.resource.data.updated_by == request.auth.uid;
      allow update: if canWriteMeetingChild(resource.data.meeting_id) &&
        request.resource.data.meeting_id == resource.data.meeting_id &&
        request.resource.data.updated_by == request.auth.uid;
      allow delete: if canWriteMeetingChild(resource.data.meeting_id);
    }

    match /meeting_attendees/{attendeeId} {
      allow read: if canReadMeetingChild(resource.data.meeting_id);
      allow create: if canWriteMeetingChild(request.resource.data.meeting_id);
      allow update: if false;
      allow delete: if canWriteMeetingChild(resource.data.meeting_id);
    }

    match /meeting_agenda_items/{itemId} {
      allow read: if canReadMeetingChild(resource.data.meeting_id);
      allow create: if canWriteMeetingChild(request.resource.data.meeting_id);
      allow update: if canWriteMeetingChild(resource.data.meeting_id) &&
        request.resource.data.meeting_id == resource.data.meeting_id;
      allow delete: if canWriteMeetingChild(resource.data.meeting_id);
    }

    match /resources/{resourceId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id);
      allow update: if canManage(resource.data.organization_id) && immutableOrg();
      allow delete: if canManage(resource.data.organization_id);
    }

    match /handovers/{handoverId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id);
      allow update: if canManage(resource.data.organization_id) && immutableOrg();
      allow delete: if canManage(resource.data.organization_id);
    }

    match /announcements/{announcementId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id);
      allow update: if canManage(resource.data.organization_id);
      allow delete: if isAdmin(resource.data.organization_id);
    }

    match /events/{eventId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if canManage(request.resource.data.organization_id);
      allow update: if canManage(resource.data.organization_id) && immutableOrg();
      allow delete: if canManage(resource.data.organization_id);
    }

    match /activity_logs/{activityId} {
      allow read: if isMember(resource.data.organization_id);
      allow create: if isMember(request.resource.data.organization_id) &&
        request.resource.data.actor_user_id == request.auth.uid &&
        request.resource.data.keys().hasOnly(["id", "organization_id", "actor_user_id", "action", "metadata", "created_at"]);
      allow update, delete: if false;
    }

    match /invites/{inviteId} {
      allow read: if verifiedEmail() && (
        request.auth.token.email == resource.data.email ||
        isMember(resource.data.organization_id)
      );
      allow create, update, delete: if false;
    }
  }
}
